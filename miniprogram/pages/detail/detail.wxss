.page{min-height:100vh}.media{height:540rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(145deg,#edf4fc,#fff)}.media image{width:480rpx;height:480rpx}.media text{color:#98a5b6;font-size:18rpx}.body{padding:42rpx 32rpx 70rpx}.eyebrow{color:#2463eb;font-size:23rpx;font-weight:800;letter-spacing:2rpx}.title{margin-top:12rpx;font-size:52rpx;font-weight:900}.en{color:#95a2b3;font-size:23rpx;margin-top:5rpx}.meta{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10rpx;margin-top:30rpx}.meta view{padding:20rpx 14rpx;background:#fff;border:1rpx solid #e3eaf3;border-radius:20rpx;display:flex;flex-direction:column}.meta text{color:#8290a3;font-size:19rpx}.meta .value{margin-top:8rpx;font-size:24rpx}.heading{font-size:32rpx;font-weight:900;margin:42rpx 0 22rpx}.step{display:flex;gap:18rpx;margin-bottom:20rpx;align-items:flex-start}.step>text{flex:0 0 52rpx;width:52rpx;height:52rpx;line-height:52rpx;text-align:center;border-radius:16rpx;background:#e7efff;color:#2463eb;font-weight:900}.step view{color:#516178;font-size:27rpx;line-height:1.7}.muscles{display:flex;flex-direction:column;gap:10rpx;padding:24rpx;margin-top:28rpx;border-radius:22rpx;background:#e8f8f2;color:#327c68}.muscles .muscle-title{font-size:27rpx}.muscles text{font-size:24rpx}.actions{display:flex;gap:16rpx;margin-top:28rpx}.actions button{flex:1;background:#fff;border:1rpx solid #dce5f0;color:#10213f;font-weight:800;border-radius:22rpx}.actions .save{background:#2463eb;color:#fff;border:0}.actions .saved{background:#e34e73}.notice{margin-top:34rpx;color:#8b97a8;font-size:21rpx;line-height:1.7;text-align:center}
