.page{min-height:100vh}.hero{padding:34rpx 32rpx 42rpx;background:radial-gradient(circle at 90% 15%,#e8f0ff,#fff 62%);border-bottom:1rpx solid #e3eaf3}.brand{display:flex;align-items:center;font-size:38rpx;font-weight:900}.mark{width:64rpx;height:64rpx;line-height:64rpx;text-align:center;color:#fff;font-size:26rpx;border-radius:22rpx 22rpx 22rpx 8rpx;background:linear-gradient(135deg,#2463eb,#54c9a9);margin-right:16rpx}.brand button{margin:0 0 0 auto;padding:0 24rpx;height:66rpx;line-height:66rpx;color:#fff;background:#2463eb;border-radius:20rpx;font-size:24rpx;font-weight:700}.eyebrow{margin-top:54rpx;color:#2463eb;font-size:24rpx;font-weight:800;letter-spacing:3rpx}.title{font-size:66rpx;line-height:1.12;font-weight:900;letter-spacing:-3rpx;margin-top:18rpx}.title text{display:block;color:#54c9a9}.subtitle{margin-top:22rpx;color:#65758d;font-size:28rpx;line-height:1.7}.search{margin-top:28rpx;height:94rpx;padding:0 26rpx;display:flex;align-items:center;border:3rpx solid #2463eb;border-radius:28rpx;background:#fff;box-shadow:0 18rpx 38rpx rgba(36,99,235,.12)}.search text{font-size:38rpx;color:#7a8aa0;margin-right:16rpx}.search input{flex:1;font-size:28rpx}.stats{display:flex;margin-top:24rpx;padding:22rpx 12rpx;border-radius:26rpx;background:rgba(255,255,255,.88);box-shadow:0 12rpx 32rpx rgba(24,48,77,.07)}.stats view{flex:1;display:flex;flex-direction:column;align-items:center;border-right:1rpx solid #e3eaf3}.stats view:last-child{border:0}.stats .num{color:#2463eb;font-size:40rpx}.stats .num.mint{color:#38b994}.stats text{color:#7d8ca0;font-size:20rpx;margin-top:4rpx}.part-scroll{background:#fff;white-space:nowrap}.parts{display:inline-flex;padding:24rpx 28rpx;gap:14rpx}.parts button{margin:0;padding:0 28rpx;height:68rpx;line-height:68rpx;border:1rpx solid #dfe7f1;border-radius:20rpx;background:#fff;color:#5d6c82;font-size:24rpx}.parts button.active{background:#2463eb;color:#fff;box-shadow:0 10rpx 24rpx rgba(36,99,235,.2)}.toolbar{padding:28rpx 30rpx 20rpx;display:flex;align-items:center;justify-content:space-between;color:#8190a3;font-size:24rpx}.picker{padding:18rpx 24rpx;background:#fff;border:1rpx solid #e1e8f1;border-radius:18rpx;color:#394b66;font-weight:700}.grid{display:grid;grid-template-columns:1fr 1fr;gap:20rpx;padding:0 24rpx}.card{overflow:hidden;background:#fff;border:1rpx solid #e3eaf3;border-radius:26rpx;box-shadow:0 12rpx 30rpx rgba(24,48,77,.06)}.media{height:280rpx;position:relative;background:linear-gradient(145deg,#eef4fb,#fff)}.media image{width:100%;height:100%}.media button{position:absolute;right:14rpx;top:14rpx;width:64rpx;height:64rpx;line-height:62rpx;padding:0;border-radius:20rpx;background:rgba(255,255,255,.94);color:#e34e73;font-size:34rpx}.content{padding:20rpx}.tags{display:flex;gap:8rpx}.tags text{padding:7rpx 12rpx;border-radius:10rpx;background:#eaf1ff;color:#2463eb;font-size:19rpx;font-weight:700}.tags text+text{background:#e8f8f2;color:#238d72}.name{margin-top:16rpx;font-size:30rpx;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.en{height:30rpx;color:#a1adbc;font-size:19rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.target{margin-top:12rpx;color:#6c7b8f;font-size:22rpx}.more{margin:34rpx auto;padding:0 34rpx;height:76rpx;line-height:76rpx;border:1rpx solid #cfdaea;border-radius:22rpx;background:#fff;color:#2463eb;font-size:24rpx;font-weight:800}.empty{margin:20rpx 24rpx;padding:80rpx 20rpx;text-align:center;background:#fff;border-radius:24rpx;color:#7b899d}.license{padding:48rpx 34rpx 60rpx;color:#8794a6;font-size:20rpx;line-height:1.7;text-align:center}
